# Postgres connection.
# Local dev uses docker-compose (see ../../docker-compose.yml), exposed on host port 5433.
DATABASE_URL="postgresql://portfolio:portfolio@localhost:5433/portfolio?schema=public"

# API server port (web runs on 3000).
PORT=3333

# Optional: read-only GitHub PAT to pull real activity stats (calendar, languages,
# per-exhibit timelines) for the nightly job. Without it, the activity snapshot
# stays a tagged placeholder (totalContribs=1863 is the one real number).
# GITHUB_TOKEN=

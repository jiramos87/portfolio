# Postgres connection.
# Local dev uses docker-compose (see ../../docker-compose.yml), exposed on host port 5433.
DATABASE_URL="postgresql://portfolio:portfolio@localhost:5433/portfolio?schema=public"

# API server port (web runs on 3000).
PORT=3333

# GitHub tokens for the live activity pull (`pnpm --filter api activity:refresh`).
# Without them the activity snapshot stays a tagged placeholder.
#   GITHUB_TOKEN       — classic PAT, scope: read:user  → contribution count + heatmap
#   GITHUB_REPO_TOKEN  — fine-grained PAT, Contents: read-only → repo stats
# (The language block shows curated "primary stacks", not raw bytes.)
# GITHUB_TOKEN=
# GITHUB_REPO_TOKEN=
